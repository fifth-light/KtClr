load("@bazel_skylib//rules:copy_file.bzl", "copy_file")

copy_file(
    name = "ilasm",
    src = select({
        "//config:linux_x86_64": "@ilasm_linux_x64//:ilasm",
        "//config:linux_arm64": "@ilasm_linux_arm64//:ilasm",
        "//config:macos_x86_64": "@ilasm_osx_x64//:ilasm",
        "//config:macos_arm64": "@ilasm_osx_arm64//:ilasm",
        "//config:windows_x86_64": "@ilasm_win_x64//:ilasm",
    }),
    out = "ilasm.exe",
    is_executable = True,
    visibility = ["//visibility:public"],
)
